          clearSelection();\
          // \uc0\u26816 \u26597 \u26159 \u21542 \u20840 \u37096 \u25918 \u32622 \
          if (Object.values(placedMap).every(v => v)) \{\
            markStepDone(1);\
            showGlobalMessage('\uc0\u9989  \u20840 \u37096 \u20301 \u32622 \u27491 \u30906 \u65281 \u20320 \u20570 \u23565 \u20102 \u27161 \u38988 \u12289 \u27491 \u25991 \u12289 \u32626 \u21517 \u21516 \u26085 \u26399 \u22021 \u25850 \u20301 \u12290 ', 'success');\
          \}\
        \});\
      \});\
\
      // \uc0\u28857 \u20987 \u31354 \u30333 \u21462 \u28040 \u36873 \u25321 \
      document.addEventListener('click', function cancelHandler(e) \{\
        if (!e.target.closest('.draggable-card') && !e.target.closest('.drop-zone')) \{\
          clearSelection();\
        \}\
      \}, \{once: false\});\
    \}\
\
    // ---------- \uc0\u27493 \u39588 2\u65306 \u27491 \u25991 \u35201 \u32032 \u25490 \u24207  (\u28857 \u20987 \u21477 \u23376 \u25918 \u20837 \u39034 \u24207 \u27133 ) ----------\
    function renderStep2() \{\
      activityContainer.innerHTML = `\
        <div class="activity-box">\
          <div class="instruction"><span class="icon">\uc0\u55357 \u56610 </span> \u21855 \u20107 \u27491 \u25991 \u35201 \u25353 \u27425 \u24207 \u65281 \u40670 \u25802 \u21477 \u23376 \u65292 \u20877 \u40670 \u19979 \u26041 \u25976 \u23383 \u26684 \u65292 \u25490 \u20986 \u27491 \u30906 \u38918 \u24207 \u12290 </div>\
          <div class="card-pool" id="sentencePool">\
            <div class="draggable-card" data-sentence="1" id="s1">\uc0\u55357 \u56550  \u36986 \u22833 \u21655 \u21673 \u29289 \u21697 \u65311 \u21946 \u37002 \u24230 \u12289 \u24190 \u26178 \u21780 \u35211 \u65311 </div>\
            <div class="draggable-card" data-sentence="2" id="s2">\uc0\u55357 \u56589  \u29289 \u21697 \u26377 \u21673 \u29305 \u24501 \u65311 \u65288 \u38991 \u33394 \u12289 \u27161 \u35468 \u12289 \u20839 \u35023 \u29289 \u21697 \u65289 </div>\
            <div class="draggable-card" data-sentence="3" id="s3">\uc0\u55357 \u56542  \u22914 \u26377 \u25342 \u29554 \u65292 \u40670 \u27171 \u32879 \u32097 \u65311 \u26377 \u20871 \u37228 \u35613 \u65311 </div>\
          </div>\
          <div class="slot-row" id="slotRow">\
            <div class="slot" data-slot="1">1\uc0\u65039 \u8419 </div>\
            <div class="slot" data-slot="2">2\uc0\u65039 \u8419 </div>\
            <div class="slot" data-slot="3">3\uc0\u65039 \u8419 </div>\
          </div>\
          <p style="text-align:center; color:#6b5b3c;">\uc0\u27491 \u30906 \u27425 \u24207 \u65306 1.\u22833 \u29289 +\u26178 \u22320  \u8594  2.\u29305 \u24501  \u8594  3.\u32879 \u32097 \u26041 \u24335 </p>\
        </div>\
      `;\
\
      let selectedSentence = null;\
      const sentences = document.querySelectorAll('#sentencePool .draggable-card');\
      const slots = document.querySelectorAll('#slotRow .slot');\
      const placedSentences = \{1: null, 2: null, 3: null\}; // \uc0\u35760 \u24405 \u21738 \u20010 \u21477 \u23376 \u25918 \u20837 \u20102 \u21738 \u20010 \u27133 \
\
      function clearSelection2() \{\
        sentences.forEach(s => s.classList.remove('selected'));\
        selectedSentence = null;\
        slots.forEach(sl => sl.classList.remove('highlight-slot'));\
      \}\
\
      sentences.forEach(s => \{\
        s.addEventListener('click', (e) => \{\
          e.stopPropagation();\
          if (s.classList.contains('placed')) return;\
          clearSelection2();\
          s.classList.add('selected');\
          selectedSentence = s;\
          // \uc0\u39640 \u20142 \u31354 \u27133 \
          slots.forEach(sl => \{\
            if (!sl.classList.contains('filled')) sl.classList.add('highlight-slot');\
          \});\
        \});\
      \});\
\
      slots.forEach(slot => \{\
        slot.addEventListener('click', (e) => \{\
          e.stopPropagation();\
          if (!selectedSentence) return;\
          if (slot.classList.contains('filled')) return;\
          const slotNum = parseInt(slot.dataset.slot);\
          // \uc0\u25918 \u32622 \u21477 \u23376 \
          slot.textContent = selectedSentence.textContent.substring(0,2) + '\'85'; // \uc0\u31616 \u30701 \u26174 \u31034 \
          slot.classList.add('filled');\
          selectedSentence.classList.add('placed');\
          placedSentences[slotNum] = selectedSentence.dataset.sentence;\
          clearSelection2();\
          // \uc0\u26816 \u26597 \u26159 \u21542 \u20840 \u37096 \u25918 \u32622 \
          if (Object.values(placedSentences).every(v => v !== null)) \{\
            // \uc0\u26816 \u26597 \u39034 \u24207 : \u27491 \u30830 \u39034 \u24207 \u24212 \u20026  sentence1, sentence2, sentence3 \u23545 \u24212 \u27133 1,2,3\
            if (placedSentences[1] === '1' && placedSentences[2] === '2' && placedSentences[3] === '3') \{\
              markStepDone(2);\
              showGlobalMessage('\uc0\u9989  \u38918 \u24207 \u27491 \u30906 \u65281 \u36319 \u20303 \u21602 \u20491 \u27425 \u24207 \u23531 \u27491 \u25991 \u23601 \u21873 \u21895 \u12290 ', 'success');\
            \} else \{\
              showGlobalMessage('\uc0\u10060  \u27425 \u24207 \u37679 \u21655 \u21568 \u65281 \u35430 \u19979 \u36319  1\u8594 2\u8594 3 \u25490 \u36942 \u12290 ', 'error');\
              // \uc0\u19981 \u26631 \u35760 \u23436 \u25104 \u65292 \u20801 \u35768 \u37325 \u32622 \
            \}\
          \}\
        \});\
      \});\
\
      document.addEventListener('click', function cancel2(e) \{\
        if (!e.target.closest('.draggable-card') && !e.target.closest('.slot')) \{\
          clearSelection2();\
        \}\
      \}, \{once: false\});\
    \}\
\
    // ---------- \uc0\u27493 \u39588 3\u65306 \u32626 \u21517 \u19982 \u26085 \u26399 \u26684 \u24335  (\u36873 \u25321 \u27491 \u30830 \u26684 \u24335 ) ----------\
    function renderStep3() \{\
      activityContainer.innerHTML = `\
        <div class="activity-box">\
          <div class="instruction"><span class="icon">\uc0\u55357 \u56523 </span> \u37002 \u20491 \u32626 \u21517 \u21516 \u26085 \u26399 \u26684 \u24335 \u20808 \u21873 \u65311 \u25779 \u19968 \u19979 \u36984 \u25799 \u12290 </div>\
          <div id="formatOptions">\
            <label class="radio-option" id="optA">\
              <input type="radio" name="format" value="A"> \
              <div style="text-align:right; width:100%;">\
                <div>\uc0\u38515 \u19968 \u24515 </div>\
                <div>\uc0\u20108 \u38646 \u19968 \u22235 \u24180 \u21313 \u26376 \u20845 \u26085 </div>\
              </div>\
            </label>\
            <label class="radio-option" id="optB">\
              <input type="radio" name="format" value="B">\
              <div style="text-align:left;">\
                <div>\uc0\u20108 \u38646 \u19968 \u22235 \u24180 \u21313 \u26376 \u20845 \u26085 </div>\
                <div>\uc0\u38515 \u19968 \u24515 </div>\
              </div>\
            </label>\
          </div>\
          <p style="color:#7b5e3b; margin-top:8px;">\uc0\u55357 \u56481  \u25552 \u31034 \u65306 \u32626 \u21517 \u21946 \u19978 \u38754 \u65292 \u26085 \u26399 \u21946 \u19979 \u38754 \u65292 \u32780 \u19988 \u35201 <strong>\u38752 \u21491 \u23565 \u40778 </strong>\u12290 </p>\
        </div>\
      `;\
\
      const radioA = document.getElementById('optA');\
      const radioB = document.getElementById('optB');\
      const radioInputs = document.querySelectorAll('input[name="format"]');\
\
      function checkFormat() \{\
        const selected = document.querySelector('input[name="format"]:checked');\
        if (!selected) return;\
        if (selected.value === 'A') \{\
          markStepDone(3);\
          showGlobalMessage('\uc0\u9989  \u27491 \u30906 \u65281 \u32626 \u21517 \u21516 \u26085 \u26399 \u35201 \u38752 \u21491 \u65292 \u32780 \u19988 \u21517 \u21946 \u19978 \u12289 \u26085 \u26399 \u21946 \u19979 \u12290 ', 'success');\
        \} else \{\
          showGlobalMessage('\uc0\u10060  \u21602 \u20491 \u21780 \u21873 \u21902 \u12290 \u35352 \u20303 \u38752 \u21491 \u65292 \u21517 \u19978 \u26085 \u26399 \u19979 \u12290 ', 'error');\
        \}\
      \}\
\
      radioInputs.forEach(input => \{\
        input.addEventListener('change', checkFormat);\
      \});\
      // \uc0\u28857 \u20987 \u25972 \u20010 label\u20063 \u21487 \u20197 \u36873 \u20013 \
      radioA.addEventListener('click', () => \{ document.querySelector('#optA input').checked = true; checkFormat(); \});\
      radioB.addEventListener('click', () => \{ document.querySelector('#optB input').checked = true; checkFormat(); \});\
    \}\
\
    // ---------- \uc0\u27493 \u39588 4\u65306 \u24110 \u26446 \u24535 \u26126 \u20889 \u21551 \u20107  (\u32508 \u21512 \u36873 \u25321 ) ----------\
    function renderStep4() \{\
      activityContainer.innerHTML = `\
        <div class="activity-box">\
          <div class="instruction"><span class="icon">\uc0\u55358 \u56785 \u8205 \u55356 \u57235 </span> \u26446 \u24535 \u26126 \u21780 \u35211 \u21655 \u32972 \u21253 \u65292 \u24171 \u20322 \u25536 \u36820 \u27491 \u30906 \u22021 \u21855 \u20107 \u20839 \u23481 \u65281 </div>\
          <div style="background:#faf5e7; border-radius:18px; padding:14px; margin-bottom:16px;">\
            <strong>\uc0\u55357 \u56534  \u36039 \u26009 \u37325 \u28331 \u65306 </strong>\u40657 \u33394 Nike\u32972 \u21253 \u65292 5\u26376 15\u26085 \u19978 \u21320 10\u40670 \u21946 \u22294 \u26360 \u39208 \u36986 \u22833 \u65292 \u20839 \u26377 \u37666 \u21253 \u12289 \u23416 \u29983 \u35657 \u12290 \u38651 \u35441 91234567\u65292 \u37228 \u35613 200\u20803 \u12290 \
          </div>\
          <div id="q1" style="margin-bottom:22px;">\
            <p><strong>1. \uc0\u27161 \u38988 \u25033 \u35442 \u20418 \u65311 </strong></p>\
            <button class="btn choice-btn" data-correct="true">\uc0\u23563 \u29289 \u21855 \u20107 </button>\
            <button class="btn choice-btn" data-correct="false">\uc0\u23563 \u20154 \u21855 \u20107 </button>\
          </div>\
          <div id="q2" style="margin-bottom:22px;">\
            <p><strong>2. \uc0\u27491 \u25991 \u31532 \u19968 \u21477 \u25033 \u35442 \u20418 \u65311 </strong></p>\
            <button class="btn choice-btn" data-correct="true">\uc0\u26412 \u20154 \u26044 5\u26376 15\u26085 \u19978 \u21320 10\u26178 \u22312 \u22294 \u26360 \u39208 \u36986 \u22833 Nike\u32972 \u21253 \'85\'85</button>\
            <button class="btn choice-btn" data-correct="false">\uc0\u26412 \u20154 \u22021 \u29399 \u21780 \u35211 \u21655 \u65292 \u35531 \u24171 \u24537 \'85\'85</button>\
          </div>\
          <div id="q3" style="margin-bottom:22px;">\
            <p><strong>3. \uc0\u32626 \u21517 \u25033 \u35442 \u23531 \u65311 </strong></p>\
            <button class="btn choice-btn" data-correct="true">\uc0\u26446 \u24535 \u26126 </button>\
            <button class="btn choice-btn" data-correct="false">\uc0\u38515 \u19968 \u24515 </button>\
          </div>\
          <div id="q4">\
            <p><strong>4. \uc0\u26085 \u26399 \u25033 \u35442 \u20418 \u65311 </strong></p>\
            <button class="btn choice-btn" data-correct="true">2025\uc0\u24180 5\u26376 15\u26085 </button>\
            <button class="btn choice-btn" data-correct="false">\uc0\u20108 \u38646 \u19968 \u22235 \u24180 \u21313 \u26376 \u20845 \u26085 </button>\
          </div>\
          <p id="step4Feedback" style="text-align:center; font-weight:bold; margin-top:12px;"></p>\
        </div>\
      `;\
\
      const correctAnswers = \{ q1: false, q2: false, q3: false, q4: false \};\
      const feedbackEl = document.getElementById('step4Feedback');\
\
      function checkAllDone() \{\
        if (correctAnswers.q1 && correctAnswers.q2 && correctAnswers.q3 && correctAnswers.q4) \{\
          markStepDone(4);\
          showGlobalMessage('\uc0\u55356 \u57225  \u20840 \u37096 \u27491 \u30906 \u65281 \u20320 \u24050 \u32147 \u24171 \u26446 \u24535 \u26126 \u23436 \u25104 \u23563 \u29289 \u21855 \u20107 \u21895 \u65281 ', 'success');\
        \}\
      \}\
\
      document.querySelectorAll('.choice-btn').forEach(btn => \{\
        btn.addEventListener('click', function(e) \{\
          const parentId = this.parentElement.id; // q1,q2,q3,q4\
          const isCorrect = this.dataset.correct === 'true';\
          // \uc0\u28165 \u38500 \u21516 \u32452 \u20854 \u20182 \u25353 \u38062 \u26679 \u24335 \
          const siblings = this.parentElement.querySelectorAll('.choice-btn');\
          siblings.forEach(b => b.style.background = '#f9eedb');\
          if (isCorrect) \{\
            this.style.background = '#c3e6b0';\
            correctAnswers[parentId] = true;\
            feedbackEl.textContent = '\uc0\u9989  \u21602 \u20491 \u21873 \u65281 ';\
            feedbackEl.style.color = '#1e4a1e';\
          \} else \{\
            this.style.background = '#f0b8b8';\
            correctAnswers[parentId] = false;\
            feedbackEl.textContent = '\uc0\u10060  \u21780 \u21873 \u65292 \u35430 \u19979 \u21478 \u19968 \u20491 \u12290 ';\
            feedbackEl.style.color = '#8b2a2a';\
          \}\
          checkAllDone();\
        \});\
      \});\
    \}\
\
    // \uc0\u20107 \u20214 \u32465 \u23450 \
    nextBtn.addEventListener('click', goToNextStep);\
    resetBtn.addEventListener('click', resetCurrentStep);\
\
    // \uc0\u21021 \u22987 \u21270 \
    renderStep(1);\
    updateStepUI();\
\
    // \uc0\u28165 \u29702 \u20840 \u23616 \u28857 \u20987 \u30417 \u21548 \u65288 \u36991 \u20813 \u37325 \u22797 \u32465 \u23450 \u65289 \
    window.cleanupListeners = function() \{\
      // \uc0\u31616 \u21333 \u22788 \u29702 \u65292 \u37325 \u26032 \u28210 \u26579 \u26102 \u20250 \u26367 \u25442 innerHTML\u65292 \u30417 \u21548 \u22120 \u33258 \u21160 \u31227 \u38500 \
    \};\
  \})();\
</script>\
</body>\
</html>}