        case 4: renderStep4(); break;\
      \}\
    \}\
\
    // ---------- \uc0\u27493 \u39588 1\u65306 \u35748 \u35782 \u21551 \u20107 \u22235 \u20010 \u37096 \u20998  (\u25302 \u25918 /\u28857 \u20987 \u25918 \u32622 ) ----------\
    function renderStep1() \{\
      activityContainer.innerHTML = `\
