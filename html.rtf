          <div class="notice-template" id="template1">\
            <div class="drop-zone title-zone" data-accept="title" id="zone-title">\uc0\u55357 \u56524  \u27161 \u38988  (\u23621 \u20013 )</div>\
            <div class="drop-zone body-zone" data-accept="body" id="zone-body">\uc0\u55357 \u56541  \u27491 \u25991 </div>\
            <div class="signature-group">\
              <div class="drop-zone sign-zone" data-accept="signature" id="zone-signature">\uc0\u55357 \u56420  \u32626 \u21517 </div>\
              <div class="drop-zone date-zone" data-accept="date" id="zone-date">\uc0\u55357 \u56517  \u26085 \u26399 </div>\
            </div>\
          </div>\
          <div class="card-pool" id="cardPool1">\
            <div class="draggable-card" data-type="title" id="card-title">\uc0\u23563 \u29356 \u21855 \u20107 </div>\
            <div class="draggable-card" data-type="body" id="card-body">\uc0\u26412 \u20154 \u29287 \u32650 \u29399 \u26044 \u21313 \u26376 \u20116 \u26085 \u36208 \u22833 \'85\'85\u29305 \u24501 \'85\'85\u35531 \u33268 \u38651 1234 5678\u65292 \u21402 \u37228 \u12290 </div>\
            <div class="draggable-card" data-type="signature" id="card-signature">\uc0\u38515 \u19968 \u24515 </div>\
            <div class="draggable-card" data-type="date" id="card-date">\uc0\u20108 \u38646 \u19968 \u22235 \u24180 \u21313 \u26376 \u20845 \u26085 </div>\
          </div>\
        </div>\
      `;\
\
      // \uc0\u20132 \u20114 \u36923 \u36753 \
      let selectedCard = null;\
      const cards = document.querySelectorAll('#cardPool1 .draggable-card');\
      const zones = document.querySelectorAll('#template1 .drop-zone');\
      const placedMap = \{ title: false, body: false, signature: false, date: false \};\
\
      function clearSelection() \{\
        cards.forEach(c => c.classList.remove('selected'));\
        selectedCard = null;\
        zones.forEach(z => z.classList.remove('highlight'));\
      \}\
\
      cards.forEach(card => \{\
        card.addEventListener('click', (e) => \{\
          e.stopPropagation();\
          if (card.classList.contains('placed')) return;\
          clearSelection();\
          card.classList.add('selected');\
          selectedCard = card;\
          // \uc0\u39640 \u20142 \u23545 \u24212 \u21487 \u25509 \u21463 \u21306 \u22495 \
          const type = card.dataset.type;\
          zones.forEach(z => \{\
            if (z.dataset.accept === type && !z.classList.contains('filled')) \{\
              z.classList.add('highlight');\
            \}\
          \});\
        \});\
      \});\
\
      zones.forEach(zone => \{\
        zone.addEventListener('click', (e) => \{\
          e.stopPropagation();\
          if (!selectedCard) return;\
          const cardType = selectedCard.dataset.type;\
          const zoneAccept = zone.dataset.accept;\
          if (cardType !== zoneAccept || zone.classList.contains('filled')) \{\
            zone.classList.add('wrong-flash');\
            setTimeout(() => zone.classList.remove('wrong-flash'), 500);\
            return;\
