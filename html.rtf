<script>\
  (function() \{\
    // \uc0\u29366 \u24577 \u31649 \u29702 \
    let currentStep = 1;\
    const totalSteps = 4;\
    let stepCompleted = [false, false, false, false]; // \uc0\u32034 \u24341 0~3\u23545 \u24212 \u27493 \u39588 1~4\
\
    // DOM\uc0\u20803 \u32032 \
    const stepNav = document.getElementById('stepNav');\
    const activityContainer = document.getElementById('activityContainer');\
    const globalFeedback = document.getElementById('globalFeedback');\
    const nextBtn = document.getElementById('nextBtn');\
    const resetBtn = document.getElementById('resetBtn');\
\
    // \uc0\u36741 \u21161 \u20989 \u25968 \
    function updateStepUI() \{\
      const dots = stepNav.querySelectorAll('.step-dot');\
      dots.forEach((dot, idx) => \{\
        const step = idx + 1;\
        dot.classList.remove('active', 'done');\
        if (step === currentStep) dot.classList.add('active');\
        if (stepCompleted[idx]) dot.classList.add('done');\
      \});\
      // \uc0\u19979 \u19968 \u27493 \u25353 \u38062 \u29366 \u24577 \
      if (stepCompleted[currentStep-1]) \{\
        nextBtn.disabled = false;\
        nextBtn.textContent = currentStep === totalSteps ? '\uc0\u55356 \u57225  \u23436 \u25104 ' : '\u19979 \u19968 \u27493  \u10145 \u65039 ';\
      \} else \{\
        nextBtn.disabled = true;\
        nextBtn.textContent = '\uc0\u35531 \u23436 \u25104 \u27963 \u21205  \u11013 \u65039 ';\
      \}\
      // \uc0\u37325 \u32622 \u25353 \u38062 \u26174 \u31034 \
      resetBtn.style.display = (currentStep === 1 || currentStep === 2) ? 'inline-block' : 'none';\
    \}\
\
    function showGlobalMessage(msg, type) \{\
      globalFeedback.style.display = 'block';\
      globalFeedback.textContent = msg;\
      globalFeedback.className = 'feedback-message ' + (type === 'success' ? 'success' : 'error');\
      if (type === 'success') \{\
        setTimeout(() => \{ globalFeedback.style.display = 'none'; \}, 3000);\
      \}\
    \}\
\
    function markStepDone(step) \{\
      if (!stepCompleted[step-1]) \{\
        stepCompleted[step-1] = true;\
        updateStepUI();\
      \}\
    \}\
\
    // \uc0\u37325 \u32622 \u24403 \u21069 \u27493 \u39588 \
    function resetCurrentStep() \{\
      stepCompleted[currentStep-1] = false;\
      globalFeedback.style.display = 'none';\
      renderStep(currentStep);\
      updateStepUI();\
    \}\
\
    // \uc0\u19979 \u19968 \u27493 \
    function goToNextStep() \{\
      if (!stepCompleted[currentStep-1]) return;\
      if (currentStep < totalSteps) \{\
        currentStep++;\
        renderStep(currentStep);\
        updateStepUI();\
        globalFeedback.style.display = 'none';\
      \} else \{\
        // \uc0\u20840 \u37096 \u23436 \u25104 \
        activityContainer.innerHTML = `\
          <div class="activity-box" style="text-align:center;">\
            <div style="font-size:3rem;">\uc0\u55356 \u57225 \u55356 \u57286 \u55356 \u57225 </div>\
            <h2 style="color:#4b3a2b; margin:16px 0;">\uc0\u20320 \u22909 \u21499 \u21568 \u65281 </h2>\
            <p style="font-size:1.2rem; color:#5b4636;">\uc0\u20320 \u24050 \u32147 \u23416 \u26371 \u21855 \u20107 \u22021 \u26684 \u24335 \u21862 \u65281 </p>\
            <p style="font-size:1rem;">\uc0\u27161 \u38988  \'b7 \u27491 \u25991 (\u22833 \u29289 /\u26178 \u22320 /\u29305 \u24501 /\u32879 \u32097 ) \'b7 \u32626 \u21517  \'b7 \u26085 \u26399 </p>\
            <button class="btn primary" id="restartAllBtn">\uc0\u55357 \u56580  \u24478 \u38957 \u29609 \u36942 </button>\
          </div>\
        `;\
        document.getElementById('restartAllBtn')?.addEventListener('click', restartAll);\
        nextBtn.style.display = 'none';\
        resetBtn.style.display = 'none';\
        globalFeedback.style.display = 'none';\
      \}\
    \}\
\
    function restartAll() \{\
      currentStep = 1;\
      stepCompleted = [false, false, false, false];\
      nextBtn.style.display = 'inline-block';\
      resetBtn.style.display = 'inline-block';\
      globalFeedback.style.display = 'none';\
      renderStep(1);\
      updateStepUI();\
    \}\
\
    // \uc0\u28210 \u26579 \u21508 \u27493 \u39588 \
    function renderStep(step) \{\
      activityContainer.innerHTML = '';\
      switch(step) \{\
        case 1: renderStep1(); break;\
